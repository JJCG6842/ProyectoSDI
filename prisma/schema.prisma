generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id             String     @id @default(uuid())
  nombre         String     @unique
  lastname       String
  email          String     @unique
  dni            Int        @unique
  password       String
  salidas        Salida[]
  role           Role       @default(Almacenero)
  status         UserStatus @default(Habilitado)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Category {
  id            String         @id @default(uuid())
  name          String         @unique
  description   String
  createAt      DateTime       @default(now())
  updateAt      DateTime       @updatedAt
  subcategories Subcategory[]
  marcas        Marca[]
  products      Products[]
}

model Subcategory {
  id           String        @id @default(uuid())
  name         String        @unique
  description  String
  categories   Category[]
  products     Products[]
  createAt     DateTime      @default(now())
  updateAt     DateTime      @updatedAt
}

model Marca {
  id          String       @id @default(uuid())
  name        String       @unique
  description String
  categories  Category[]
  createAt    DateTime     @default(now())
  updateAt    DateTime     @updatedAt
  products    Products[]
}

model Almacen {
  id          String     @id @default(uuid())
  nombre      String
  descripcion String
  direccion   String
  telefono    String
  products    Products[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Products {
  id            String            @id @default(uuid())
  image         String
  name          String            @unique
  description   String
  marcaId       String?
  quantity      Float             @default(0)
  status        ProductStatus     @default(Outstock)
  state         ProductState      @default(Habilitado)
  model         String
  categoryId    String
  subcategoryId String
  almacenId     String
  almacen       Almacen           @relation(fields: [almacenId], references: [id])
  entrances     EntranceDetalle[]
  salidas       SalidaDetalle[]
  category      Category          @relation(fields: [categoryId], references: [id])
  subcategory   Subcategory       @relation(fields: [subcategoryId], references: [id])
  marca         Marca?            @relation(fields: [marcaId], references: [id])
  createAt      DateTime          @default(now())
  updateAt      DateTime          @updatedAt
}

model Supplier {
  id          String     @id @default(uuid())
  ruc         String     @unique
  address     String
  name        String     @unique
  phone       Int        @unique
  description String
  entrances   Entrance[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Entrance {
  id         String            @id @default(uuid())
  supplierId String?
  createdAt  DateTime          @default(now())
  detalles   EntranceDetalle[]
  supplier   Supplier?         @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model EntranceDetalle {
  id            String         @id @default(uuid())
  entranceId    String
  productId     String
  quantity      Float
  serialNumbers SerialNumber[]
  product       Products       @relation(fields: [productId], references: [id])
  entrance      Entrance       @relation(fields: [entranceId], references: [id], onDelete: Cascade)
}

model SerialNumber {
  id        String          @id @default(uuid())
  serial    String
  detalleId String
  detalle   EntranceDetalle @relation(fields: [detalleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Salida {
  id        String          @id @default(uuid())
  createdAt DateTime        @default(now())
  detalles  SalidaDetalle[]
  userId    String
  user      Users           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SalidaDetalle {
  id        String   @id @default(uuid())
  salidaId  String
  productId String
  quantity  Float
  product   Products @relation(fields: [productId], references: [id])
  salida    Salida   @relation(fields: [salidaId], references: [id], onDelete: Cascade)
}

enum ProductStatus {
  Instock
  Outstock
}

enum Role {
  Administrador
  Almacenero
}

enum UserStatus {
  Habilitado
  Deshabilitado
}

enum ProductState {
  Habilitado
  Deshabilitado
}
